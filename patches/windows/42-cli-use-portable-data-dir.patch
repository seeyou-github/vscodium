+fn get_portable_cli_root() -> Option<PathBuf> {
+	if let Some(portable_dir) = std::env::var_os("VSCODE_PORTABLE") {
+		return Some(PathBuf::from(portable_dir).join("cli"));
+	}
+
+	let exe = std::env::current_exe().ok()?;
+	let bin_dir = exe.parent()?;
+	if bin_dir.file_name().and_then(|name| name.to_str()) != Some("bin") {
+		return None;
+	}
+
+	let app_dir = bin_dir.parent()?;
+	let portable_data_dir = app_dir.join("data");
+	if portable_data_dir.exists() {
+		return Some(portable_data_dir.join("cli"));
+	}
+
+	None
+}
